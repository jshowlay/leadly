{
  "name": "dentily",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "predev": "node scripts/check-node.mjs",
    "predev:log": "node scripts/check-node.mjs",
    "predev:safe": "node scripts/check-node.mjs",
    "predev:turbo": "node scripts/check-node.mjs",
    "predev:ipv4": "node scripts/check-node.mjs",
    "predev:3456": "node scripts/check-node.mjs",
    "predev:clean": "node scripts/check-node.mjs",
    "predev:loopback": "node scripts/check-node.mjs",
    "prestart": "node scripts/check-node.mjs",
    "clean": "rm -rf .next node_modules/.cache",
    "rebuild": "npm run clean && npm run build",
    "test:port": "node scripts/ping-server.mjs",
    "diagnose": "node scripts/diagnose.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:3010": "PORT=3010 node scripts/doctor.mjs",
    "free:3000": "lsof -tiTCP:3000 -sTCP:LISTEN 2>/dev/null | xargs kill -9 2>/dev/null; lsof -nP -iTCP:3000 -sTCP:LISTEN 2>/dev/null || echo 'Port 3000 is free.'",
    "dev:log": "node scripts/dev-banner.mjs && next dev -p 3000 -H 0.0.0.0 2>&1 | tee dev-server.log",
    "dev:boot": "bash scripts/start-dev.sh",
    "dev": "node scripts/dev-banner.mjs && next dev -p 3000 -H 0.0.0.0",
    "dev:safe": "node scripts/dev-banner.mjs && NODE_OPTIONS='--max-old-space-size=4096' next dev -p 3000 -H 0.0.0.0",
    "dev:turbo": "node scripts/dev-banner.mjs && next dev -p 3000 --turbo -H 0.0.0.0",
    "dev:loopback": "node scripts/dev-banner.mjs && next dev -p 3000 -H 127.0.0.1",
    "dev:ipv4": "node scripts/dev-banner.mjs && next dev -p 3000 -H 127.0.0.1",
    "dev:3456": "DEV_PORT=3456 node scripts/dev-banner.mjs && next dev -p 3456 -H 0.0.0.0",
    "dev:3010": "node scripts/dev-banner.mjs && next dev -p 3010 -H 0.0.0.0",
    "dev:clean": "npm run clean && node scripts/dev-banner.mjs && next dev -p 3000 -H 0.0.0.0",
    "build": "node scripts/clean-next-if-present.mjs && next build",
    "start": "next start -p 3000",
    "preview": "npm run build && npm run start",
    "start:3010": "next start -p 3010",
    "preview:3010": "npm run build && next start -p 3010",
    "lint": "next lint",
    "test": "vitest run",
    "generate-sample-pack": "GENERATE_SAMPLE_PACK=1 vitest run lib/sample-pack.test.ts",
    "generate-sample-austin-dl": "WRITE_DENTILY_SAMPLE_AUSTIN_CSV=1 vitest run lib/dentily-sample-austin-csv.build.test.ts"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^17.7.0",
    "styled-jsx": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "autoprefixer": "^10.4.27",
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
